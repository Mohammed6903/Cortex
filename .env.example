# Copy to .env and fill in. .env is gitignored — never commit real keys.

# LLM provider for the engine / UI scratch session.
# One of: mock | qwen | openai | claude | vertex   (default: mock = deterministic, offline)
CORTEX_LLM_PROVIDER=qwen

# Qwen Cloud (Alibaba DashScope) — get a key at https://home.qwencloud.com/api-keys
DASHSCOPE_API_KEY=your-qwen-key-here

# --- optional ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_CLOUD_PROJECT=            # for CORTEX_LLM_PROVIDER=vertex (uses ADC)
# CORTEX_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# CORTEX_SCRATCH_DB_PATH=/tmp/cortex_scratch.db
# CORTEX_BRAIN_DB_PATH=~/.cortex/brain.db   # your persistent daily brain (the /brain UI)
